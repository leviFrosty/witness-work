{
  "cli": {
    "version": ">= 7.3.0",
    "promptToConfigurePushNotifications": false,
    "appVersionSource": "remote"
  },
  "build": {
    "development-simulator": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": true
      },
      "env": {
        "APP_VARIANT": "development"
      },
      "node": "20.14.0"
    },

    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "APP_VARIANT": "development"
      },
      "node": "20.14.0"
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview"
    },
    "production": {
      "channel": "production",
      "autoIncrement": true,
      "node": "20.14.0",
      "ios": {
        "image": "latest"
      },
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "production-local": {
      "channel": "production",
      "autoIncrement": true,
      "node": "20.14.0",
      "ios": {
        "image": "latest"
      },
      "env": {
        "APP_VARIANT": "production"
      }
    },
    "production-simulator": {
      "distribution": "internal",
      "channel": "production",
      "ios": {
        "simulator": true,
        "image": "latest"
      },
      "node": "20.14.0",
      "env": {
        "APP_VARIANT": "production",
        "SENTRY_DISABLE_AUTO_UPLOAD": "true",
        "ENTRY_FILE": "src/index.js"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6469723047"
      }
    }
  }
}
