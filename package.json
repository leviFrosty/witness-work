    "expo-crypto": "~57.0.0",
    "expo-dev-client": "~57.0.5",
    "expo-device": "~57.0.0",
    "expo-document-picker": "~57.0.0",
    "expo-file-system": "~57.0.0",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.0",
    "expo-haptics": "~57.0.0",
    "expo-image": "~57.0.0",
    "expo-image-manipulator": "~57.0.2",
    "expo-image-picker": "~57.0.2",
    "expo-insights": "~57.0.2",
    "expo-linking": "~57.0.2",
    "expo-localization": "~57.0.0",
    "expo-location": "~57.0.2",
    "expo-media-library": "~57.0.1",
    "expo-network": "~57.0.0",
    "expo-notifications": "~57.0.3",
    "expo-sharing": "~57.0.3",
    "expo-splash-screen": "~57.0.2",
    "expo-sqlite": "~57.0.0",
    "expo-status-bar": "~57.0.0",
    "expo-store-review": "~57.0.0",
    "expo-system-ui": "~57.0.0",
    "expo-task-manager": "~57.0.2",
    "expo-updates": "~57.0.6",
    "fflate": "^0.8.2",
    "fuse.js": "^7.3.0",
    "i18n-js": "^4.5.1",
    "jest-expo": "~57.0.1",
    "lodash": "^4.18.1",
    "lottie-react-native": "7.3.8",
    "madge": "^8.0.0",
    "moment": "^2.30.1",
    "prop-types": "^15.8.1",
    "react": "19.2.3",
    "react-compiler-runtime": "19.0.0-beta-af1b7da-20250417",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-calendars": "^1.1313.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-international-phone-number": "^0.8.7",
    "react-native-keyboard-aware-scroll-view": "^0.9.5",
    "react-native-maps": "1.27.2",
    "react-native-mmkv": "^3.3.3",
    "react-native-pager-view": "8.0.2",
    "react-native-purchases": "10.0.1",
    "react-native-reanimated": "~4.5.1",
    "react-native-reanimated-carousel": "^4.0.3",
    "react-native-safe-area-context": "5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-worklets": "0.10.2",
    "reanimated-color-picker": "^4.2.0",
    "semver": "^7.7.2",
    "tamagui": "^1.144.4",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.6",
    "@eslint/js": "10.0.1",
    "@testing-library/react-native": "^12.9.0",
    "@types/lodash": "^4.17.20",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^19.1.0",
    "@types/semver": "^7.7.1",
    "baseline-browser-mapping": "^2.10.22",
    "eslint": "10.3.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "6.0.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-compiler": "19.1.0-rc.2",
    "eslint-plugin-react-hooks": "7.1.1",
    "expo-doctor": "^1.18.18",
    "globals": "17.6.0",
    "husky": "^9.1.7",
    "i18n-auto-translation": "2.2.3",
    "prettier": "^3.6.2",
    "prettier-plugin-jsdoc": "^1.3.3",
    "react-test-renderer": "^19.2.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.59.3",
    "typescript-go": "npm:typescript@7.0.1-rc",
    "vitest": "^3.2.6"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-reanimated",
        "react-native-worklets"
      ]
    },
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-keyboard-aware-scroll-view"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts?(x)"
    ]
  },
  "packageManager": "pnpm@11.1.1+sha512.d1fdf5f73c617b64fa1a56a81c3c8dfe0e966e33a6010aa256b517ae77be21d93e05affc0de1a83b0e4f29d569f68b446ae8f068cd7247c0bb3df0fb4d7bdf9a",
  "pnpm": {
    "overrides": {
      "shell-quote": ">=1.8.4"
    }
  }
}
