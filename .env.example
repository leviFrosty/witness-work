# Two env files (both gitignored):
#   .env            — DEVELOPMENT values (loaded by expo start / dev builds)
#   .env.production — PRODUCTION values (loaded when NODE_ENV=production and
#                     sourced by scripts/build-prod-auto-submit.sh for local
#                     production builds; keep in sync with `eas env:list production`)
# Copy this file to either and fill in the appropriate values.
EXPO_PUBLIC_REVENUECAT_APPLE_API_KEY=
SENTRY_AUTH_TOKEN=
AZURE_TRANSLATOR_KEY=
AZURE_TRANSLATOR_REGION=eastus
APP_VARIANT=development # development | production
EXPO_PUBLIC_SENTRY_PROJECT=jw-time
EXPO_PUBLIC_SENTRY_ORG=levi-wilkerson
EXPO_PUBLIC_SILENT=false
# Notes Import — optional. Point at a dev/staging ww-proxy so the App Attest
# dev-bypass never touches production, and set the bypass token (must match the
# dev worker's NOTES_IMPORT_DEV_BYPASS_TOKEN) so the simulator can run the flow.
# In .env.production, leave BOTH blank so the app uses the production proxy.
EXPO_PUBLIC_NOTES_IMPORT_BASE_URL=
EXPO_PUBLIC_NOTES_IMPORT_DEV_BYPASS=
