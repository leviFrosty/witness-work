# Learn more https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/

# Native
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local
.env

# typescript
*.tsbuildinfo

# google
googleServiceAccount.json

# Windows
%ProgramData%/

android/
ios/

# @bacons/apple-targets generated entitlements
targets/*/generated.entitlements

# @bacons/apple-targets generated asset catalog metadata
# (sourced from `colors:` / `icon:` in expo-target.config.js)
targets/*/Assets.xcassets/**/Contents.json

# Compiled tamagui config
.tamagui/

# Local Builds
build-*
*.apk

# Cache
.cache

# Agentic tools
.cursor
.claude

# Local e2e build cache
.e2e/
