{
  "name": "witness-work",
  "version": "1.41.0",
  "main": "src/index.js",
  "scripts": {
    "dev": "APP_VARIANT=development expo start --ios",
    "dev:prod": "expo start --no-dev --minify",
    "ios": "expo run:ios",
    "clean": "rm -rf node_modules .tamagui .expo .cache *.tar.gz ios",
    "prebuild": "pnpm sync:widget-shared && expo prebuild --platform ios --clean",
    "sync:widget-shared": "node ./scripts/sync-widget-shared.mjs",
    "build": "pnpm sync:widget-shared && eas build -p ios --profile development-simulator --local",
    "build:production": "pnpm sync:widget-shared && eas build -p ios --profile production-simulator --local",
    "build:prod-auto-submit": "./scripts/build-prod-auto-submit.sh",
    "translate": "bun run ./scripts/translate.ts",
    "bump-version": "bun run ./scripts/bump-version.js",
    "prepare": "husky",
    "test": "vitest",
    "testFinal": "vitest run",
    "check:all": "concurrently 'pnpm run testFinal' 'pnpm run typecheck' 'pnpm run lint' 'pnpm run doctor'",
    "testVitest": "",
    "updateSnapshots": "jest -u --coverage=false",
    "fmt": "prettier --write . --log-level warn --cache",
    "typecheck": "node_modules/typescript-go/bin/tsc -p ./tsconfig.json",
    "lint": "eslint . --cache --cache-location .cache/.eslintcache",
    "doctor": "expo-doctor",
    "deps": "madge --ts-config ./tsconfig.json src/app/App.tsx -c"
  },
  "dependencies": {
    "@bacons/apple-targets": "0.2.1",
    "@expo-google-fonts/inter": "^0.2.3",
    "@expo-google-fonts/kalam": "^0.4.1",
    "@fortawesome/fontawesome-svg-core": "^6.7.2",
    "@fortawesome/free-brands-svg-icons": "^6.7.2",
    "@fortawesome/free-regular-svg-icons": "^6.7.2",
    "@fortawesome/free-solid-svg-icons": "^6.7.2",
    "@fortawesome/react-native-fontawesome": "^0.3.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-menu/menu": "^2.0.0",
    "@react-native-picker/picker": "^2.11.4",
    "@react-navigation/bottom-tabs": "^7.15.9",
    "@react-navigation/drawer": "^7.9.8",
    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.10",
    "@sentry/react-native": "~7.11.0",
    "@shopify/flash-list": "2.0.2",
    "@shopify/react-native-skia": "^2.6.2",
    "@tamagui/babel-plugin": "^1.144.4",
    "@tamagui/config": "^1.144.4",
    "@tamagui/toast": "^1.144.4",
    "awesome-phonenumber": "^7.5.0",
    "axios": "^1.15.2",
    "babel-plugin-react-compiler": "19.0.0-beta-af1b7da-20250417",
    "burnt": "^0.12.2",
    "concurrently": "^9.2.1",
    "dotenv": "^16.6.1",
    "expo": "^57.0.4",
    "expo-alternate-app-icons": "^8.0.0",
    "expo-application": "~57.0.0",
    "expo-asset": "~57.0.3",
    "expo-audio": "^57.0.0",
    "expo-background-task": "^57.0.2",
    "expo-blur": "~57.0.0",
    "expo-checkbox": "~57.0.0",
    "expo-clipboard": "~57.0.0",
